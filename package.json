    "@types/react-dom": "18.3.7",
    "@visx/event": "4.0.0",
    "@visx/group": "4.0.0",
    "@visx/heatmap": "4.0.0",
    "@visx/pattern": "4.0.0",
    "@visx/responsive": "4.0.0",
    "@visx/scale": "4.0.0",
